# Copy this file to .env.local and fill in your keys.
# IMPORTANT: Do NOT commit .env.local to git.

# Gemini API key (required for AI features)
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Optional: a separate key for translation (falls back to VITE_GEMINI_API_KEY if omitted)
VITE_GEMINI_TRANSLATE_API_KEY=AIzaSyA3OJBLAmf36m7ZxVQeVPZvZ_WIZw72NdA

# Serper API key (for images/videos/news/places/products)
VITE_SERPER_API_KEY=6935bcdff9aeca9a8967ce037cb99ff4e48ffea2

# Optional: Google CSE visual fallback (enable only if you plan to use CSE for visuals)
# VITE_GOOGLE_CSE_JSON_KEY=
# VITE_GOOGLE_CSE_CX=
# VITE_USE_CSE_VISUALS=false

# News providers
# NewsData.io (recommended). You can provide a single key or multiple keys (comma/semicolon/newline separated)
# VITE_NEWSDATA_API_KEY=YOUR_NEWSDATA_API_KEY
# VITE_NEWSDATA_API_KEYS=KEY1,KEY2;KEY3

# Optional: GNews (used as an additional source if provided)
# VITE_GNEWS_API_KEY=YOUR_GNEWS_API_KEY
